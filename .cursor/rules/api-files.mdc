# API & File Upload Patterns

## Chunked File Uploads

### Large File Upload (50MB chunks)

Pattern from `src/api/uploadOrtho.ts`:

```tsx
const CHUNK_SIZE = 50 * 1024 * 1024; // 50MB

export async function uploadLargeFile(
  file: File,
  onProgress: (percent: number) => void,
  signal?: AbortSignal,
): Promise<string> {
  const {
    data: { session },
  } = await supabase.auth.getSession();
  if (!session) throw new Error("Not authenticated");

  const totalChunks = Math.ceil(file.size / CHUNK_SIZE);
  const uploadId = generateUploadId();

  // Check token expiration for long uploads
  if (needsTokenRefresh(session)) {
    await supabase.auth.refreshSession();
  }

  for (let chunkIndex = 0; chunkIndex < totalChunks; chunkIndex++) {
    if (signal?.aborted) throw new Error("Upload cancelled");

    const start = chunkIndex * CHUNK_SIZE;
    const end = Math.min(start + CHUNK_SIZE, file.size);
    const chunk = file.slice(start, end);

    const formData = new FormData();
    formData.append("file", chunk);
    formData.append("chunkIndex", chunkIndex.toString());
    formData.append("totalChunks", totalChunks.toString());
    formData.append("uploadId", uploadId);

    await fetch("/api/upload-chunk", {
      method: "POST",
      headers: { Authorization: `Bearer ${session.access_token}` },
      body: formData,
      signal,
    });

    onProgress(Math.round(((chunkIndex + 1) / totalChunks) * 100));
  }

  return uploadId;
}

function needsTokenRefresh(session: Session): boolean {
  const expiresAt = session.expires_at! * 1000;
  const fiveMinutes = 5 * 60 * 1000;
  return Date.now() + fiveMinutes > expiresAt;
}
```

## Upload Progress Notifications

### Ant Design Notification Pattern

From `src/hooks/useUploadNotification.tsx`:

```tsx
import { notification } from "antd";

export function useUploadNotification() {
  const [notificationApi, contextHolder] = notification.useNotification();

  const showProgress = (filename: string, percent: number) => {
    notificationApi.open({
      key: `upload-${filename}`,
      message: "Uploading...",
      description: (
        <div>
          <div>{filename}</div>
          <Progress percent={percent} status="active" />
        </div>
      ),
      duration: 0, // Don't auto-close
    });
  };

  const showSuccess = (filename: string) => {
    notificationApi.success({
      key: `upload-${filename}`,
      message: "Upload Complete",
      description: `${filename} uploaded successfully`,
      duration: 3,
    });
  };

  const showError = (filename: string, error: string) => {
    notificationApi.error({
      key: `upload-${filename}`,
      message: "Upload Failed",
      description: error,
      duration: 5,
    });
  };

  return { showProgress, showSuccess, showError, contextHolder };
}
```

## Upload Cancellation

### AbortController Pattern

```tsx
function UploadComponent() {
  const abortControllerRef = useRef<AbortController | null>(null);
  const [isUploading, setIsUploading] = useState(false);

  const handleUpload = async (file: File) => {
    abortControllerRef.current = new AbortController();
    setIsUploading(true);

    try {
      await uploadLargeFile(file, (percent) => console.log(`Progress: ${percent}%`), abortControllerRef.current.signal);
      message.success("Upload complete");
    } catch (error) {
      if (error.name === "AbortError") {
        message.warning("Upload cancelled");
      } else {
        message.error(`Upload failed: ${error.message}`);
      }
    } finally {
      setIsUploading(false);
      abortControllerRef.current = null;
    }
  };

  const handleCancel = () => {
    abortControllerRef.current?.abort();
  };

  return (
    <>
      <Upload customRequest={({ file }) => handleUpload(file as File)}>
        <Button>Upload File</Button>
      </Upload>
      {isUploading && (
        <Button onClick={handleCancel} danger>
          Cancel Upload
        </Button>
      )}
    </>
  );
}
```

## File Validation

### Ant Design Upload Validation

From `src/components/Upload/UploadModal.tsx`:

```tsx
const beforeUpload = (file: File) => {
  // Validate file type
  const validTypes = [".tif", ".tiff", ".geojson", ".gpkg"];
  const isValidType = validTypes.some((ext) => file.name.toLowerCase().endsWith(ext));

  if (!isValidType) {
    message.error(`Only ${validTypes.join(", ")} files are supported`);
    return Upload.LIST_IGNORE;
  }

  // Validate file size (e.g., 5GB limit)
  const maxSize = 5 * 1024 * 1024 * 1024; // 5GB
  if (file.size > maxSize) {
    message.error("File must be smaller than 5GB");
    return Upload.LIST_IGNORE;
  }

  return true;
};

// Usage
<Upload beforeUpload={beforeUpload} accept=".tif,.tiff,.geojson,.gpkg" maxCount={1}>
  <Button icon={<UploadOutlined />}>Select File</Button>
</Upload>;
```

## API Error Handling

### Consistent Error Response

```tsx
export class ApiError extends Error {
  constructor(
    message: string,
    public statusCode: number,
    public code?: string,
  ) {
    super(message);
    this.name = "ApiError";
  }
}

export async function apiRequest<T>(url: string, options?: RequestInit): Promise<T> {
  const {
    data: { session },
  } = await supabase.auth.getSession();

  const response = await fetch(url, {
    ...options,
    headers: {
      "Content-Type": "application/json",
      ...(session && { Authorization: `Bearer ${session.access_token}` }),
      ...options?.headers,
    },
  });

  if (!response.ok) {
    const error = await response.json().catch(() => ({}));
    throw new ApiError(error.message || "Request failed", response.status, error.code);
  }

  return response.json();
}
```

## Supabase Storage

### Upload to Supabase Storage

```tsx
export async function uploadToStorage(bucket: string, path: string, file: File): Promise<string> {
  const { data, error } = await supabase.storage.from(bucket).upload(path, file, {
    cacheControl: "3600",
    upsert: false, // Fail if file exists
  });

  if (error) throw error;

  // Get public URL
  const {
    data: { publicUrl },
  } = supabase.storage.from(bucket).getPublicUrl(data.path);

  return publicUrl;
}
```

### Download from Storage

```tsx
export async function downloadFile(bucket: string, path: string): Promise<Blob> {
  const { data, error } = await supabase.storage.from(bucket).download(path);

  if (error) throw error;
  return data;
}
```

## Form Integration

### Upload Modal Pattern

```tsx
function UploadModal({ visible, onClose }: ModalProps) {
  const [form] = Form.useForm();
  const [fileList, setFileList] = useState<UploadFile[]>([]);
  const [isUploading, setIsUploading] = useState(false);

  const handleSubmit = async (values: FormValues) => {
    if (fileList.length === 0) {
      message.error("Please select a file");
      return;
    }

    setIsUploading(true);
    try {
      const file = fileList[0].originFileObj as File;
      const uploadId = await uploadLargeFile(file, (percent) => {
        // Update progress
      });

      // Save metadata to database
      await supabase.from("v2_datasets").insert({
        file_name: file.name,
        upload_id: uploadId,
        ...values,
      });

      message.success("Upload complete");
      form.resetFields();
      setFileList([]);
      onClose();
    } catch (error) {
      message.error(`Upload failed: ${error.message}`);
    } finally {
      setIsUploading(false);
    }
  };

  return (
    <Modal open={visible} onCancel={onClose} footer={null}>
      <Form form={form} onFinish={handleSubmit}>
        <Form.Item label="File" required>
          <Upload
            fileList={fileList}
            onChange={({ fileList }) => setFileList(fileList)}
            beforeUpload={() => false} // Manual upload
          >
            <Button>Select File</Button>
          </Upload>
        </Form.Item>

        <Form.Item name="description" label="Description">
          <Input.TextArea />
        </Form.Item>

        <Button type="primary" htmlType="submit" loading={isUploading}>
          Upload
        </Button>
      </Form>
    </Modal>
  );
}
```

