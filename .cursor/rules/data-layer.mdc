# Data Layer Patterns

## React Query + Supabase

### Custom Hook Pattern

**Always wrap useQuery/useMutation in custom hooks:**

```tsx
// src/hooks/useDatasets.ts
import { useQuery } from "@tanstack/react-query";
import { supabase } from "../config";

export function useDatasets() {
  return useQuery({
    queryKey: ["datasets"],
    queryFn: async () => {
      const { data, error } = await supabase.from("v2_datasets").select("*").order("created_at", { ascending: false });

      if (error) throw error;
      return data;
    },
    staleTime: 5 * 60 * 1000, // 5 minutes
  });
}
```

### Query Key Convention

```tsx
// Entity-based keys
["datasets"][("datasets", id)][("datasets", id, "labels")][("datasets", { filter })][ // All datasets // Single dataset // Nested resource // With filters
  // User-scoped keys
  ("userDatasets", userId)
][("userProfile", userId)];
```

### Mutations with Optimistic Updates

```tsx
export function useUpdateDataset() {
  const queryClient = useQueryClient();

  return useMutation({
    mutationFn: async ({ id, ...updates }: UpdateDatasetInput) => {
      const { data, error } = await supabase.from("v2_datasets").update(updates).eq("id", id).select().single();

      if (error) throw error;
      return data;
    },
    onSuccess: (data, variables) => {
      // Invalidate related queries
      queryClient.invalidateQueries(["datasets", variables.id]);
      queryClient.invalidateQueries(["datasets"]);
    },
    onError: (error) => {
      message.error(`Update failed: ${error.message}`);
    },
  });
}
```

### Conditional Queries

```tsx
export function useDatasetLabels({ datasetId, enabled = true }) {
  return useQuery({
    queryKey: ["datasets", datasetId, "labels"],
    queryFn: async () => {
      const { data, error } = await supabase.from("v2_labels").select("*").eq("dataset_id", datasetId);

      if (error) throw error;
      return data;
    },
    enabled: enabled && !!datasetId, // Only run if enabled AND datasetId exists
  });
}
```

### Dependent Queries

```tsx
export function useDatasetWithLabels(datasetId: number) {
  const { data: dataset } = useDataset(datasetId);
  const { data: labels } = useDatasetLabels({
    datasetId,
    enabled: !!dataset, // Only fetch labels after dataset loads
  });

  return { dataset, labels };
}
```

## Real-time Subscriptions

### Subscription Pattern

```tsx
export function useDatasetSubscription(userId: string | undefined) {
  const queryClient = useQueryClient();

  useEffect(() => {
    if (!userId) return;

    const channel = supabase
      .channel("dataset_changes")
      .on(
        "postgres_changes",
        {
          event: "UPDATE",
          schema: "public",
          table: "v2_statuses",
        },
        async (payload) => {
          // Validate ownership
          const { data: datasetInfo } = await supabase
            .from("v2_datasets")
            .select("user_id, file_name")
            .eq("id", payload.new.dataset_id)
            .single();

          if (datasetInfo?.user_id !== userId) return;

          // Invalidate queries
          await queryClient.invalidateQueries(["userDatasets", userId]);

          // Optional: Show notification
          if (isProcessingComplete(payload.new)) {
            message.success(`Processing complete: ${datasetInfo.file_name}`);
          }
        },
      )
      .subscribe();

    return () => {
      supabase.removeChannel(channel);
    };
  }, [userId, queryClient]);
}
```

### Query Invalidation Strategy

```tsx
// Targeted invalidation (faster, preferred)
queryClient.invalidateQueries(["datasets", datasetId]);

// Broad invalidation (when relationships change)
queryClient.invalidateQueries(["datasets"]); // Invalidates all dataset queries

// Exact match only (rare, very specific)
queryClient.invalidateQueries({ queryKey: ["datasets"], exact: true });
```

## Authentication Patterns

### Auth Context (src/hooks/useAuthProvider.tsx pattern)

```tsx
interface AuthContextType {
  user: User | null;
  session: Session | null;
  isLoading: boolean;
  signOut: () => Promise<void>;
}

export function useAuthProvider(): AuthContextType {
  const [user, setUser] = useState<User | null>(null);
  const [session, setSession] = useState<Session | null>(null);
  const [isLoading, setIsLoading] = useState(true);

  useEffect(() => {
    // Get initial session
    supabase.auth.getSession().then(({ data: { session } }) => {
      setSession(session);
      setUser(session?.user ?? null);
      setIsLoading(false);
    });

    // Listen for auth changes
    const {
      data: { subscription },
    } = supabase.auth.onAuthStateChange((_event, session) => {
      setSession(session);
      setUser(session?.user ?? null);
    });

    return () => subscription.unsubscribe();
  }, []);

  const signOut = async () => {
    await supabase.auth.signOut();
    setUser(null);
    setSession(null);
  };

  return { user, session, isLoading, signOut };
}
```

### Protected Queries

```tsx
export function useUserPrivileges() {
  const { user } = useAuth();

  return useQuery({
    queryKey: ["userPrivileges", user?.id],
    queryFn: async () => {
      if (!user) return null;

      const { data, error } = await supabase.from("v2_users").select("is_auditor, is_admin").eq("id", user.id).single();

      if (error) throw error;
      return data;
    },
    enabled: !!user,
    staleTime: 10 * 60 * 1000, // 10 minutes (rarely changes)
  });
}
```

### Token Refresh for Long Operations

```tsx
// Pattern from src/api/uploadOrtho.ts
export async function uploadLargeFile(file: File) {
  const {
    data: { session },
  } = await supabase.auth.getSession();
  if (!session) throw new Error("Not authenticated");

  // Check if token expires soon (within 5 minutes)
  const expiresAt = session.expires_at! * 1000;
  const expiringThreshold = 5 * 60 * 1000;

  if (Date.now() + expiringThreshold > expiresAt) {
    const {
      data: { session: newSession },
    } = await supabase.auth.refreshSession();
    if (!newSession) throw new Error("Failed to refresh session");
  }

  // Proceed with long-running operation
  return await performUpload(file, session.access_token);
}
```

## Error Handling

### Consistent Error Messages

```tsx
export function useDatasets() {
  return useQuery({
    queryKey: ["datasets"],
    queryFn: async () => {
      const { data, error } = await supabase.from("v2_datasets").select("*");

      if (error) {
        // Provide context in error message
        throw new Error(`Failed to fetch datasets: ${error.message}`);
      }

      return data;
    },
    meta: {
      // Optional: React Query error handling
      onError: (error: Error) => {
        console.error("Dataset query error:", error);
        message.error("Unable to load datasets. Please try again.");
      },
    },
  });
}
```

### Retry Configuration

```tsx
// For critical queries
useQuery({
  queryKey: ["criticalData"],
  queryFn: fetchCriticalData,
  retry: 3,
  retryDelay: (attemptIndex) => Math.min(1000 * 2 ** attemptIndex, 30000),
});

// For non-critical queries
useQuery({
  queryKey: ["optionalData"],
  queryFn: fetchOptionalData,
  retry: false, // Don't retry
});
```

## Cache Configuration

### Global Defaults (in main.tsx)

```tsx
const queryClient = new QueryClient({
  defaultOptions: {
    queries: {
      staleTime: 2 * 60 * 1000, // 2 minutes (reasonable default)
      gcTime: 10 * 60 * 1000, // 10 minutes (garbage collection)
      retry: 1, // Retry once on failure
      refetchOnWindowFocus: false, // Disable for geospatial app
    },
  },
});
```

### Per-Query Overrides

```tsx
// Real-time data (short staleTime)
useQuery({
  queryKey: ["processingStatus", datasetId],
  queryFn: fetchStatus,
  staleTime: 10 * 1000, // 10 seconds
  refetchInterval: 30 * 1000, // Poll every 30 seconds
});

// Static data (long staleTime)
useQuery({
  queryKey: ["countries"],
  queryFn: fetchCountries,
  staleTime: Infinity, // Never goes stale
});
```

## Row Level Security (RLS)

### Public vs Private Queries

```tsx
// Public datasets (anyone can read)
export function usePublicDatasets() {
  return useQuery({
    queryKey: ["publicDatasets"],
    queryFn: async () => {
      const { data, error } = await supabase.from("v2_datasets").select("*").eq("is_published", true); // RLS automatically applies

      if (error) throw error;
      return data;
    },
  });
}

// User's own datasets (RLS filters by user_id)
export function useUserDatasets() {
  const { user } = useAuth();

  return useQuery({
    queryKey: ["userDatasets", user?.id],
    queryFn: async () => {
      const { data, error } = await supabase.from("v2_datasets").select("*"); // RLS automatically filters by user_id

      if (error) throw error;
      return data;
    },
    enabled: !!user,
  });
}
```

