# TypeScript Patterns

## Interface Naming

```tsx
// ✅ Prefix with 'I'
interface IDataset {
  /* ... */
}
interface ILabel {
  /* ... */
}

// Component props (no prefix)
interface DataTableProps {
  /* ... */
}
interface MapComponentProps {
  /* ... */
}

// Context types (suffix with 'Type')
interface AuthContextType {
  /* ... */
}
```

## Enums for Controlled Vocabularies

```tsx
// Use string enums for readability
export enum IDataAccess {
  OPEN = "open",
  RESTRICTED = "restricted",
  CLOSED = "closed",
}

export enum ILicense {
  CC_BY = "CC BY 4.0",
  CC_BY_SA = "CC BY-SA 4.0",
  CC_BY_NC = "CC BY-NC 4.0",
}

// Usage
const dataset: IDataset = {
  license: ILicense.CC_BY,
  data_access: IDataAccess.OPEN,
};
```

## Domain Types

### Dataset Types (src/types/dataset.ts pattern)

```tsx
export interface IDataset {
  id: number;
  file_name: string;
  user_id: string;
  bbox?: string;
  data_access: IDataAccess;
  license: ILicense;
  created_at: string;
  updated_at: string;
}

export interface DatasetProgress {
  dataset_id: number;
  is_upload_done: boolean;
  is_ortho_done: boolean;
  is_metadata_done: boolean;
  is_cog_done: boolean;
  is_deadwood_done: boolean;
  has_error: boolean;
  current_status: "idle" | "processing" | "error";
}
```

### Label Types (src/types/labels.ts pattern)

```tsx
export interface ILabel {
  id: number;
  dataset_id: number;
  label_data: ILabelData;
  geometry: GeoJSON.Geometry;
  created_at: string;
}

export enum ILabelData {
  DEADWOOD = "deadwood",
  TREE = "tree",
  ANNOTATION = "annotation",
}
```

## Utility Types

### Partial Updates

```tsx
// For update operations
type UpdateDatasetInput = Partial<IDataset> & { id: number };

// Usage
const updateData: UpdateDatasetInput = {
  id: 123,
  file_name: "new_name.tif", // Only update file_name
};
```

### Form Values

```tsx
// Extract form-specific fields
type DatasetFormValues = Pick<IDataset, "file_name" | "license" | "data_access">;

// Or define explicitly
interface UploadFormValues {
  file: File;
  description: string;
  license: ILicense;
}
```

### API Response Types

```tsx
// Supabase returns arrays
type DatasetsResponse = IDataset[];
type DatasetResponse = IDataset | null;

// With error handling
type QueryResult<T> = {
  data: T | null;
  error: Error | null;
  isLoading: boolean;
};
```

## Type Guards

```tsx
export function isValidDataAccess(value: string): value is IDataAccess {
  return Object.values(IDataAccess).includes(value as IDataAccess);
}

// Usage
if (isValidDataAccess(input)) {
  dataset.data_access = input; // TypeScript knows input is IDataAccess
}
```

## Generic Types

```tsx
// For reusable components
interface TableProps<T> {
  data: T[];
  columns: ColumnDefinition<T>[];
  onRowClick?: (row: T) => void;
}

// Usage
<Table<IDataset> data={datasets} columns={datasetColumns} />;
```

## Avoid

```tsx
// ❌ Don't use 'any'
const data: any = response;

// ✅ Use 'unknown' and narrow
const data: unknown = response;
if (typeof data === "object" && data !== null) {
  // Safe to access properties
}

// ❌ Don't use optional chaining excessively
const name = data?.user?.profile?.name?.firstName?.value;

// ✅ Validate shape explicitly
if (data?.user?.profile) {
  const { name } = data.user.profile;
}
```

